<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Phoenix Share">
    <meta name="author" content="Phoenix">
    <link rel="icon" href="/icons/logo.jpeg">
    <link href="
https://cdn.jsdelivr.net/npm/tailwindcss@3.3.3/tailwind.min.css
" rel="stylesheet">
   <link rel="stylesheet" href="/styles/download.css">
   <link rel="manifest" href="/manifest.json">
    <title>Phoenix Share - Download</title>
</head>
<body>
<div class="container">
    <img class="logo" src="logo_trans.png" alt="Logo">
    <h1>Phoenix Share</h1>
    <div class="download-container">
        <h2>Download File</h2>
        <p>File Name: <%= fileName %></p>
        <p>Uploaded By: <%= uploader_username %></p>
        <p>Upload Time: <%= upload_time %></p>
        <a href="/download-file/<%= fileName %>" class="download-button" data-fileName="<%= fileName %>">
  Download
</a>

      </div>
    <div class="footer">
        Return to <a href="/" class="text-blue-500">Home</a>
    </div>
  <p id="Error" style="color: red;"></p>
    </div>
</div>
<script src="/scripts/download.js"></script>
</body>
</html>
