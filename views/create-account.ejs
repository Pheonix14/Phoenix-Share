<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Account</title>
  
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-4bw+/aepP/YC94hEpVNVgiZdgIC5+VKNBQNGCHeKRQN+PtmoHDEXuppvnDJzQIu9" crossorigin="anonymous">
  
  <!-- MDBootstrap CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/mdbootstrap@5.2.3/css/mdb.min.css">
  
  <!-- Custom CSS -->
  <style>
    body {
      background-color: #fff4e6;
    }

    .container {
      height: 100vh;
    }

    .form-control:focus {
      box-shadow: none;
    }

    .btn-primary {
      background-color: #ff5722;
      border-color: #ff5722;
      transition: background-color 0.3s;
    }

    .btn-primary:hover {
      background-color: #ff7043;
      border-color: #ff7043;
    }

    .btn-primary:active {
      background-color: #ff8a65;
      border-color: #ff8a65;
    }

    .btn-primary:focus {
      background-color: #ff7043 !important;
      border-color: #ff7043 !important;
      box-shadow: none !important;
    }

    .btn-primary.disabled, .btn-primary:disabled {
      background-color: #ff5722 !important;
      border-color: #ff5722 !important;
    }

    .btn-link {
      color: #ff5722;
    }

    .btn-link:hover {
      color: #ff7043;
    }

    .btn-link:focus {
      color: #ff7043 !important;
      text-decoration: underline !important;
      box-shadow: none !important;
    }

  @media (max-width: 576px) {
    body {
      background-color: #fff; /* Adjust background color for small screens */
    }

    .container {
      padding: 20px; /* Add padding to the container for small screens */
    }

    .col-md-6 {
      max-width: 100%; /* Ensure full width for small screens */
    }

    .btn-primary {
      width: 100%; /* Make the button full width on small screens */
    }
  }

  </style>
</head>
<body>
  <div class="container">
    <div class="row justify-content-center align-items-center vh-100">
      <div class="col-md-6">
        <form class="text-center p-5" action="/create-account" method="post">
          <h1 class="mb-4" style="color: #ff5722;">Phoenix Share</h1>

          <input type="text" id="username" class="form-control mb-4" name="username" placeholder="Username" required>

          <input type="password" id="password" class="form-control mb-4" name="password" placeholder="Password" required>

          <button class="btn btn-primary btn-block my-4" type="submit">
<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-person-plus-fill" viewBox="0 0 16 16">
  <path d="M1 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1H1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
  <path fill-rule="evenodd" d="M13.5 5a.5.5 0 0 1 .5.5V7h1.5a.5.5 0 0 1 0 1H14v1.5a.5.5 0 0 1-1 0V8h-1.5a.5.5 0 0 1 0-1H13V5.5a.5.5 0 0 1 .5-.5z"/>
            </svg> Create Account</button>

          <p class="mb-4">Already have an account? <a class="btn-link" href="/login">Login</a></p>
        </form>
      </div>
    </div>
  </div>

  <!-- Bootstrap 5 JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/js/bootstrap.bundle.min.js" integrity="sha384-HwwvtgBNo3bZJJLYd8oVXjrBZt8cqVSpeBNS5n7C8IVInixGAoxmnlMuBnhbgrkm" crossorigin="anonymous"></script>
</body>
</html>
