<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Phoenix Share">
  <meta name="author" content="Phoenix">
  <link rel="icon" href="https://media.discordapp.net/attachments/1118813311308419162/1133000448815681536/OIP__2_-removebg-preview.png">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/mdbootstrap@5.2.3/css/mdb.min.css">
  <title>Phoenix Share</title>
  <style>
    body {
      background-color: #f2f2f2;
    }

    .container {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100vh;
    }

    .logo {
      max-width: 100px;
      height: auto;
    }

    h1 {
      font-size: 32px;
      margin: 20px 0;
      color: #333;
    }

    .form-container {
      width: 300px;
      padding: 20px;
      background-color: #fff;
      border: 1px solid #ddd;
      border-radius: 5px;
      box-shadow: 0px 2px 4px rgba(0, 0, 0, 0.1);
      text-align: center;
    }

    .upload-button {
      background-color: #ff5722;
      color: #fff;
      border: none;
      border-radius: 5px;
      padding: 10px 20px;
      cursor: pointer;
      transition: background-color 0.3s;
      margin-top: 20px;
    }

    .upload-button:hover {
      background-color: #ff7043;
    }

    #dragDropArea {
      width: 100%;
      height: 150px;
      border: 2px dashed #ccc;
      border-radius: 5px;
      display: flex;
      justify-content: center;
      align-items: center;
      margin-top: 20px;
      background-color: #e6e6e6;
      color: #888;
      font-weight: bold;
      cursor: pointer;
      transition: border-color 0.3s, background-color 0.3s, color 0.3s;
    }

    #dragDropArea.dragging {
      border-color: #2196f3;
      background-color: #eaf5fe;
      color: #2196f3;
    }

    .username {
      font-weight: bold;
     position: absolute;
  top: 8px;
  right: 16px;
  font-size: 18px;
      color: #333;
    }

    .footer {
      margin-top: 20px;
      font-size: 14px;
      color: #25D366;
    }

#downloadLink {
      margin-top: 20px;
      font-size: 14px;
      color: #333;
}
    
    @media (max-width: 576px) {
      body {
        background-color: #fff;
      }

      .container {
        padding: 20px;
      }

      .form-container {
        width: 100%;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="username">Welcome, <%= username %></div>
    <img class="logo" src="https://media.discordapp.net/attachments/1118813311308419162/1133000448815681536/OIP__2_-removebg-preview.png" alt="Logo">
    <h1>Phoenix Share</h1>
    <div class="form-container">
      <form id="uploadForm" action="/upload" method="POST" enctype="multipart/form-data">
        <input type="file" name="file" id="fileInput" style="display: none;">
        <label for="fileInput" class="upload-button">
   <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-file-earmark-plus-fill" viewBox="0 0 16 16">
  <path d="M9.293 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V4.707A1 1 0 0 0 13.707 4L10 .293A1 1 0 0 0 9.293 0zM9.5 3.5v-2l3 3h-2a1 1 0 0 1-1-1zM8.5 7v1.5H10a.5.5 0 0 1 0 1H8.5V11a.5.5 0 0 1-1 0V9.5H6a.5.5 0 0 1 0-1h1.5V7a.5.5 0 0 1 1 0z"/>
   </svg> Choose File
        </label>
        <div id="dragDropArea"> <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-cursor-fill" viewBox="0 0 16 16">
  <path d="M14.082 2.182a.5.5 0 0 1 .103.557L8.528 15.467a.5.5 0 0 1-.917-.007L5.57 10.694.803 8.652a.5.5 0 0 1-.006-.916l12.728-5.657a.5.5 0 0 1 .556.103z"/>
        </svg> Drag and Drop Files Here</div>
        <button type="submit" class="upload-button">
<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-cloud-arrow-up-fill" viewBox="0 0 16 16">
  <path d="M8 2a5.53 5.53 0 0 0-3.594 1.342c-.766.66-1.321 1.52-1.464 2.383C1.266 6.095 0 7.555 0 9.318 0 11.366 1.708 13 3.781 13h8.906C14.502 13 16 11.57 16 9.773c0-1.636-1.242-2.969-2.834-3.194C12.923 3.999 10.69 2 8 2zm2.354 5.146a.5.5 0 0 1-.708.708L8.5 6.707V10.5a.5.5 0 0 1-1 0V6.707L6.354 7.854a.5.5 0 1 1-.708-.708l2-2a.5.5 0 0 1 .708 0l2 2z"/>
          </svg> Upload
        </button>
        <div class="footer">
<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-lock-fill" viewBox="0 0 16 16">
  <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
   </svg> Secured With End To End Encryption
        </div>
      </form>
    </div>
    <h2 id="downloadLink">Uploaded file will be displayed here.</h2>
  </div>

  
  <script>
    const form = document.getElementById('uploadForm');
    const fileInput = document.getElementById('fileInput');
    const downloadLink = document.getElementById('downloadLink');
    const dragDropArea = document.getElementById('dragDropArea');

    form.addEventListener('submit', (event) => {
      event.preventDefault();

      const formData = new FormData();
      formData.append('file', fileInput.files[0]);

      fetch('/upload', {
        method: 'POST',
        body: formData
      })
      .then(response => response.text())
      .then(data => {
        downloadLink.innerHTML = data;
        form.reset();
      })
      .catch(error => {
        console.error('Error:', error);
      });
    });

    dragDropArea.addEventListener('dragover', (event) => {
      event.preventDefault();
      dragDropArea.classList.add('dragging');
    });

    dragDropArea.addEventListener('dragleave', () => {
      dragDropArea.classList.remove('dragging');
    });

    dragDropArea.addEventListener('drop', (event) => {
      event.preventDefault();
      dragDropArea.classList.remove('dragging');
      fileInput.files = event.dataTransfer.files;
    });
  </script>

<!-- Bootstrap 5 JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
