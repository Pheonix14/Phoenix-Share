<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Phoenix Share">
    <meta name="author" content="Phoenix">
    <link rel="icon" href="https://media.discordapp.net/attachments/1118813311308419162/1133000448815681536/OIP__2_-removebg-preview.png">
    <link href="
https://cdn.jsdelivr.net/npm/tailwindcss@3.3.3/tailwind.min.css
" rel="stylesheet">
    <title>Phoenix Share - Error</title>
    <style>
        body {
            background-color: #121212;
            font-family: Arial, sans-serif;
            color: #fff;
        }

        .container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 20px;
        }

        .logo {
            max-width: 100px;
            height: auto;
        }

        h1 {
            font-size: 36px;
            margin: 20px 0;
        }

        .error-container {
            width: 90%;
            max-width: 320px;
            padding: 30px;
            background-color: #1e1e1e;
            border-radius: 10px;
            box-shadow: 0px 0px 20px rgba(255, 255, 255, 0.1);
            text-align: center;
        }

        .error-message {
            font-size: 24px;
            margin-bottom: 20px;
        }

        .return-button {
            background-color: #4a90e2;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 15px 30px;
            font-size: 16px;
            text-decoration: none;
            cursor: pointer;
            transition: background-color 0.3s;
            display: block;
            width: 100%;
            max-width: 200px; /* Limit button width */
        }

        .return-button:hover {
            background-color: #357abd;
        }
    </style>
</head>
<body>
<div class="container">
    <img class="logo" src="https://media.discordapp.net/attachments/1118813311308419162/1133000448815681536/OIP__2_-removebg-preview.png" alt="Logo">
    <h1>Phoenix Share</h1>
    <div class="error-container">
        <p class="error-message"><%= errorMessage %></p>
        <a href="/" class="return-button">Return to Home</a>
    </div>
</div>
</body>
</html>
