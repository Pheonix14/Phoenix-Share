<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login Page</title>
  
  <!-- Bootstrap 5 CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/css/bootstrap.min.css">
  
  <!-- MDBootstrap CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/mdbootstrap@5.2.3/css/mdb.min.css">
  
  <!-- Custom CSS -->
  <style>
    body {
      background-color: #fff4e6;
    }

    .container {
      height: 100vh;
    }

    .form-control:focus {
      box-shadow: none;
    }

    .btn-primary {
      background-color: #ff5722;
      border-color: #ff5722;
      transition: background-color 0.3s;
    }

    .btn-primary:hover {
      background-color: #ff7043;
      border-color: #ff7043;
    }

    .btn-primary:active {
      background-color: #ff8a65;
      border-color: #ff8a65;
    }

    .btn-primary:focus {
      background-color: #ff7043 !important;
      border-color: #ff7043 !important;
      box-shadow: none !important;
    }

    .btn-primary.disabled, .btn-primary:disabled {
      background-color: #ff5722 !important;
      border-color: #ff5722 !important;
    }

    .btn-link {
      color: #ff5722;
    }

    .btn-link:hover {
      color: #ff7043;
    }

    .btn-link:focus {
      color: #ff7043 !important;
      text-decoration: underline !important;
      box-shadow: none !important;
    }

      @media (max-width: 576px) {
    body {
      background-color: #fff; /* Adjust background color for small screens */
    }

    .container {
      padding: 20px; /* Add padding to the container for small screens */
    }

    .col-md-6 {
      max-width: 100%; /* Ensure full width for small screens */
    }

    .btn-primary {
      width: 100%; /* Make the button full width on small screens */
    }
      }
    
  </style>
</head>
<body>
  <div class="container">
    <div class="row justify-content-center align-items-center vh-100">
      <div class="col-md-6">
        <form class="text-center p-5" action="/login" method="post">
          <h1 class="mb-4" style="color: #ff5722;">Phoenix Share</h1>

          <input type="text" id="username" class="form-control mb-4" name="username" placeholder="Username" required>

          <input type="password" id="password" class="form-control mb-4" name="password" placeholder="Password" required>

          <button class="btn btn-primary btn-block my-4" type="submit">
<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-person-fill-lock" viewBox="0 0 16 16">
  <path d="M11 5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm-9 8c0 1 1 1 1 1h5v-1a1.9 1.9 0 0 1 .01-.2 4.49 4.49 0 0 1 1.534-3.693C9.077 9.038 8.564 9 8 9c-5 0-6 3-6 4Zm7 0a1 1 0 0 1 1-1v-1a2 2 0 1 1 4 0v1a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1h-4a1 1 0 0 1-1-1v-2Zm3-3a1 1 0 0 0-1 1v1h2v-1a1 1 0 0 0-1-1Z"/>
            </svg> Login</button>

          <p class="mb-4">Don't have an account? <a class="btn-link" href="/create-account">Create one</a></p>
        </form>
      </div>
    </div>
  </div>

  <!-- Bootstrap 5 JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
            </html>
      